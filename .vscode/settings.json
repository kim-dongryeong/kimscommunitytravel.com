{
  "workbench.iconTheme": "vscode-icons",
  "workbench.tree.indent": 16,
  "workbench.tree.renderIndentGuides": "always",
  "workbench.list.smoothScrolling": true,
  "workbench.editor.enablePreview": false,
  
  "editor.lineHeight": 1.7,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "editor.minimap.enabled": false,
  "editor.guides.indentation": true,
  "editor.guides.bracketPairs": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.renderWhitespace": "selection",
  "editor.renderLineHighlight": "all",
  "editor.rulers": [
    100
  ],
  "editor.stickyScroll.enabled": true,
  "breadcrumbs.enabled": true,
  "window.commandCenter": true,
  "window.titleBarStyle": "custom",
  "workbench.colorCustomizations": {
    "titleBar.activeBackground": "#123524",
    "titleBar.activeForeground": "#f4f1e8",
    "titleBar.inactiveBackground": "#1d4a35",
    "titleBar.inactiveForeground": "#d8d2c4",
    "activityBar.background": "#173d2b",
    "activityBar.foreground": "#f8e9bd",
    "activityBar.inactiveForeground": "#8b9a8d",
    "activityBarBadge.background": "#ff7a1a",
    "activityBarBadge.foreground": "#0f1f17",
    "sideBar.background": "#5b4b2b",
    "sideBar.foreground": "#a8b7ac",
    "sideBarTitle.foreground": "#0dd075",
    "sideBarSectionHeader.background": "#8f5c04",
    "sideBarSectionHeader.foreground": "#173d2b",
    "list.activeSelectionBackground": "#dbe7df",
    "list.activeSelectionForeground": "#173d2b",
    "list.hoverBackground": "#549978",
    "statusBar.background": "#549978",
    "statusBar.foreground": "#f4f1e8",
    "statusBar.noFolderBackground": "#123524",
    "statusBar.debuggingBackground": "#a83d12",
    "statusBar.debuggingForeground": "#fff4ec",
    "editorGroupHeader.tabsBackground": "#595857",
    "tab.activeBackground": "#fffaf2",
    "tab.activeForeground": "#173d2b",
    "tab.inactiveBackground": "#a99f8d",
    "tab.inactiveForeground": "#5f6d64",
    "tab.hoverBackground": "#f6efe4",
    "editor.lineHighlightBackground": "#61532e",
    "editorLineNumber.activeForeground": "#173d2b",
    "focusBorder": "#ff7a1a",
    "button.background": "#d9641a",
    "button.foreground": "#3af481",
    "button.hoverBackground": "#b95110"
  }
}
